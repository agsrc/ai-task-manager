# --- Database Configuration ---
quarkus.datasource.db-kind=h2
# Uses a local file so data persists between server restarts
quarkus.datasource.jdbc.url=jdbc:h2:file:./data/tasksdb;DB_CLOSE_DELAY=-1
# Note: Change to 'update' if you want to keep data between app reloads
quarkus.hibernate-orm.database.generation=drop-and-create
quarkus.hibernate-orm.log.sql=true

# --- AI Model Configuration (LangChain4j + Ollama) ---
# Default Ollama endpoint
quarkus.langchain4j.ollama.base-url=http://localhost:11434
#lightweight model
quarkus.langchain4j.ollama.chat-model.model-id=phi4-mini
quarkus.langchain4j.ollama.timeout=60s

# --- AI Tuning ---
# Limits output length to prevent runaway generation (512 tokens is ~400 words)
quarkus.langchain4j.ollama.chat-model.num-predict=512

# --- Frontend Configuration (Quinoa + React) ---
# Maps the Quarkus backend to the React Vite setup
quarkus.quinoa.ui-dir=src/main/webui
quarkus.quinoa.dev-server.port=5173